# REQUIRED: Telegram Bot Token from @BotFather
# Get from: https://t.me/botfather
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh

# REQUIRED: Secret key for relay authentication
# Generate a strong random string (min 32 chars recommended)
# Example: openssl rand -hex 32
RELAY_SECRET=your_secret_relay_key_min_32_chars

# OPTIONAL: Backend server URL (for clients)
BACKEND_URL=http://localhost:8000

# OPTIONAL: Allowed origins for CORS (comma-separated)
# Defaults to http://localhost:3000
# Production example: https://api.example.com,https://backup-api.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
